rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt']) &&
               data.keys().size() == 5 &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 256;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // 2. Wishlists
    match /wishlists/{userId}/items/{productId} {
      function isValidWishlist(data) {
        return data.keys().hasAll(['productId', 'userId', 'addedAt']) &&
               data.keys().size() == 3 &&
               data.userId == request.auth.uid &&
               isValidId(data.productId);
      }

      allow list, get: if isOwner(userId);
      allow create, delete: if isOwner(userId) && (request.method == 'delete' || isValidWishlist(incoming()));
    }

    // 3. Orders
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.fullName is string && data.fullName.size() <= 128 &&
               data.phoneNumber is string && data.phoneNumber.size() <= 15 &&
               data.county is string && data.county.size() <= 64 &&
               data.town is string && data.town.size() <= 128 &&
               data.items is list && data.items.size() > 0 &&
               data.total is number && data.total >= 0 &&
               data.status in ["Pending Confirmation", "Payment Sent", "Paid", "Processing", "Out for Delivery", "Delivered", "Cancelled"] &&
               (data.userId == null || data.userId == request.auth.uid);
      }

      function isAdmin() {
        return isSignedIn() && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          (request.auth.token.email == 'gfcollection@gmail.com' && request.auth.token.email_verified == true)
        );
      }

      allow create: if isValidOrder(incoming()) && 
                    incoming().createdAt == request.time && 
                    incoming().updatedAt == request.time;
      
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow get: if isAdmin() || 
                  (resource.data.userId == null) || 
                  (isSignedIn() && resource.data.userId == request.auth.uid);

      allow update: if isAdmin() || (
        isSignedIn() && 
        resource.data.userId == request.auth.uid && 
        isValidOrder(incoming()) &&
        incoming().updatedAt == request.time &&
        incoming().diff(resource.data).affectedKeys().hasOnly(['status', 'mpesaCode', 'updatedAt']) &&
        (incoming().status == 'Payment Sent' || resource.data.status == incoming().status)
      );
    }

    // 4. Admins (System Only)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special script
    }

    // 5. Products
    match /products/{productId} {
      function isAdmin() {
        return isSignedIn() && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          (request.auth.token.email == 'gfcollection@gmail.com' && request.auth.token.email_verified == true)
        );
      }
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    // 6. Categories
    match /categories/{categoryId} {
      function isAdmin() {
        return isSignedIn() && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          (request.auth.token.email == 'gfcollection@gmail.com' && request.auth.token.email_verified == true)
        );
      }
      allow read: if resource.data.isEnabled == true || isAdmin();
      allow write: if isAdmin();
    }

    // 7. Settings
    match /settings/{settingKey} {
      function isAdmin() {
        return isSignedIn() && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          (request.auth.token.email == 'gfcollection@gmail.com' && request.auth.token.email_verified == true)
        );
      }
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
