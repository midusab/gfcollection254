{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "User wishlist items",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "addedAt": { "type": "string" }
      },
      "required": ["productId", "userId"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "county": { "type": "string" },
        "town": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "items": { 
          "type": "array",
          "items": { "type": "object" }
        },
        "subtotal": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "total": { "type": "number" },
        "status": { 
          "type": "string",
          "enum": ["Pending Confirmation", "Payment Sent", "Paid", "Processing", "Out for Delivery", "Delivered", "Cancelled"]
        },
        "mpesaCode": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["orderId", "fullName", "phoneNumber", "county", "town", "items", "total", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "Product in the catalog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "category": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "images": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "image": { "type": "string" },
        "sizes": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "colors": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "isFeatured": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "onSale": { "type": "boolean" },
        "status": { "type": "string", "enum": ["published", "draft", "out_of_stock"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "price", "category", "status"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "isEnabled": { "type": "boolean" },
        "bannerText": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "slug"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Website settings and content",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "object" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["key", "value"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Store user profiles"
    },
    "/wishlists/{userId}/items/{productId}": {
      "schema": "Wishlist",
      "description": "User personal wishlists"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/settings/{settingKey}": {
      "schema": "Setting",
      "description": "Website configuration"
    }
  }
}
