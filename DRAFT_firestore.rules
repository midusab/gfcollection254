rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'gfcollection@gmail.com' ||
        request.auth.token.email == 'bochieng228@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'status', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.status in ['published', 'draft', 'out_of_stock'] &&
             data.image is string && data.image.size() <= 1024;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['fullName', 'phoneNumber', 'address', 'town', 'county', 'status', 'items', 'total']) &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 10 && data.phoneNumber.size() <= 15 &&
             data.status in ['Pending Confirmation', 'Payment Sent', 'Paid', 'Processing', 'Out for Delivery', 'Delivered', 'Cancelled'] &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.total is number && data.total >= 0;
    }

    // --- Rules ---

    match /products/{productId} {
      allow read: if true; // Public catalog
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId) &&
                   incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidProduct(incoming()) &&
                   incoming().createdAt == existing().createdAt &&
                   incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isValidOrder(incoming()) && isValidId(orderId) &&
                    (!isSignedIn() || incoming().userId == request.auth.uid) &&
                    incoming().status == 'Pending Confirmation' &&
                    incoming().createdAt == request.time;
      
      allow update: if isAdmin() && isValidOrder(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().orderId == existing().orderId &&
                    incoming().updatedAt == request.time && (
                      // Action: Status Update or verification
                      incoming().diff(existing()).affectedKeys().hasAny(['status', 'mpesaCode', 'updatedAt'])
                    );
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable via Firebase Console or special script
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /wishlists/{userId}/items/{productId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
